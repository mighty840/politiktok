# Database
DATABASE_URL=postgresql://politiktok:politiktok@localhost:5432/politiktok

# LLM Configuration
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1:8b
LLM_TIMEOUT_SECS=120
LLM_MAX_RETRIES=3

# Embedding
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=nomic-embed-text

# Vector Store (Qdrant)
VECTOR_STORE_URL=http://localhost:6333

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=politiktok
KEYCLOAK_CLIENT_ID=politiktok-app
KEYCLOAK_CLIENT_SECRET=

# Application
APP_URL=http://localhost:8000
ENCRYPTION_KEY=changeme-generate-a-real-key
AUTH_SECRET=changeme-generate-a-real-secret

# SearXNG
SEARXNG_URL=http://localhost:8888

# External APIs (optional)
MASTODON_INSTANCE_URL=
MASTODON_ACCESS_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
